# Database - Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# Neon Auth (required for authentication)
NEON_AUTH_BASE_URL=https://your-app.vercel.app/auth
NEON_AUTH_COOKIE_SECRET=generate-a-secure-random-secret-at-least-32-characters-long

# OpenAI API Key (for AI features)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_AUTOCOMPLETE_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: Upstash Redis (for rate limiting if needed)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token
