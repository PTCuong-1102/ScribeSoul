# ==========================================
# REQUIRED - Database
# ==========================================
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/scribesoul?sslmode=require

# ==========================================
# REQUIRED - Authentication (Auth.js v5)
# ==========================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-32-plus-character-random-secret

# ==========================================
# OPTIONAL - OAuth (leave blank to disable)
# ==========================================
GITHUB_ID=your-github-app-id
GITHUB_SECRET=your-github-app-secret

GOOGLE_ID=your-google-oauth-client-id
GOOGLE_SECRET=your-google-oauth-client-secret

# ==========================================
# REQUIRED - AI Services (OpenAI)
# ==========================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_AUTOCOMPLETE_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ==========================================
# OPTIONAL - Rate Limiting (Upstash Redis)
# ==========================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ==========================================
# OPTIONAL - Environment
# ==========================================
NODE_ENV=development

# ==========================================
# NOTES:
# 1. Generate NEXTAUTH_SECRET:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. DATABASE_URL from Neon - ensure pgvector extension enabled:
#    CREATE EXTENSION IF NOT EXISTS vector;
#
# 3. OPENAI_API_KEY from platform.openai.com
#
# 4. For Production/Vercel:
#    - Generate new NEXTAUTH_SECRET
#    - Update NEXTAUTH_URL to production domain
#    - Update OAuth credentials for production
# ==========================================
